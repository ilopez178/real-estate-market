# FRED API (St. Louis Federal Reserve)
VITE_FRED_API_KEY=your_fred_api_key_here

# Supabase (optional — for caching + push notifications)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# VAPID keys for push notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your@email.com
